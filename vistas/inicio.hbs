<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Inventario de Productos</h2>
    <a href="/agregar" class="btn btn-success"> + Agregar Nuevo</a>
</div>

<div class="card shadow">
    <div class="card-body">
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Precio</th>
                    <th>Descripción</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                {{#each productos}}
                <tr>
                    <td>{{this.nombre}}</td>
                    <td>${{this.precio}}</td>
                    <td>{{this.descripcion}}</td>
                    <td>
                      {{#if logueado}}
                        <a href="/editar/{{this._id}}" class="btn btn-warning btn-sm">Editar</a>
                        <a href="/eliminar/{{this._id}}" class="btn btn-warning btn-sm" 
                        onclick="return confirm('¿Esta seguro de eliminar este producto?')">Eliminar</a>
                      {{else}}
                          <span class="text-muted">Ver</span>
                      {{/if}}
                    </td>
                </tr>
                {{else}}
                <tr>
                    <td colspan="4" class="text-center text-muted">No hay productos registrados</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</div>
